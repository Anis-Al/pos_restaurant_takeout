<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_restaurant_takeout.KdsOrderWidget"
       t-inherit="pos_preparation_display.Order"
       t-inherit-mode="extension">

        <!-- Inject TAKEOUT badge before the card header -->
        <xpath expr="//div[hasclass('o_pdis_order_card_header_top')]" position="before">
            <div t-if="isDelivery" class="o-kds-delivery-badge">
                <i class="fa fa-motorcycle me-1"/> DELIVERY — <t t-esc="driverName"/>
            </div>
            <div t-elif="isTakeout" class="o-kds-takeout-badge">
                <i class="fa fa-shopping-bag me-1"/> TAKEOUT
            </div>
        </xpath>

    </t>

</templates>

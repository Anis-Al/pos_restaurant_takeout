<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_restaurant_takeout.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <button t-if="isTakeoutOrder" class="btn btn-secondary flex-fill o-delivery-btn" t-on-click="() => this.openDeliveryPopup()">
                <i class="fa fa-motorcycle me-1"/> Delivery
            </button>
        </xpath>
    </t>
</templates>

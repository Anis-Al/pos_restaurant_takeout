<?xml version="1.0"?>
<odoo>
    <record id="view_pos_order_form_takeout" model="ir.ui.view">
        <field name="name">pos.order.form.takeout</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='order_fields']" position="inside">
                <field name="is_takeout" widget="boolean_toggle"/>
                <field name="is_delivery" widget="boolean_toggle"/>
                <field name="driver_id" invisible="not is_delivery"/>
            </xpath>
        </field>
    </record>
</odoo>

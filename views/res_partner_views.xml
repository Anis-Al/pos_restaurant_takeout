<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_delivery_driver" model="ir.ui.view">
        <field name="name">res.partner.tree.delivery.driver</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Delivery Drivers">
                <field name="name"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_form_delivery_driver" model="ir.ui.view">
        <field name="name">res.partner.form.delivery.driver</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Delivery Driver">
                <sheet>
                    <field name="is_delivery_driver" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver name..." required="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="phone" widget="phone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_delivery_driver" model="ir.actions.act_window">
        <field name="name">Delivery Drivers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_partner_tree_delivery_driver')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_partner_form_delivery_driver')}),
        ]"/>
        <field name="domain">[('is_delivery_driver', '=', True)]</field>
        <field name="context">{'default_is_delivery_driver': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new delivery driver
            </p>
        </field>
    </record>

    <menuitem id="menu_pos_delivery_driver"
              name="Drivers"
              parent="point_of_sale.menu_point_of_sale"
              action="action_pos_delivery_driver"
              sequence="20"/>
</odoo>
